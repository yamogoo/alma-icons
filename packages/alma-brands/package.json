{
  "name": "alma-brands",
  "version": "1.2.2",
  "author": {
    "name": "yamogoo",
    "email": "grebennikovmisha@gmail.com",
    "fullName": "Mikhail Grebennikov",
    "url": "https://github.com/yamogoo"
  },
  "description": "Icons Set with Multiple Weights & Styles",
  "type": "module",
  "keywords": [
    "icons",
    "svg",
    "logos"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/icons": {
      "types": "./dist/react/icons/index.d.ts",
      "import": "./dist/react/icons/index.js"
    },
    "./react/icons/*": {
      "types": "./dist/react/icons/*.d.ts",
      "import": "./dist/react/icons/*.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./vue/icons": {
      "types": "./dist/vue/icons/index.d.ts",
      "import": "./dist/vue/icons/index.js"
    },
    "./vue/icons/*": {
      "types": "./dist/vue/icons/*.d.ts",
      "import": "./dist/vue/icons/*.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js"
    },
    "./icons/svg": "./icons",
    "./icons/svg/*": "./icons/*"
  },
  "files": [
    "icons",
    "dist",
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "ts-node --esm ./scripts/generate-manifest.ts",
    "validate": "node ./scripts/validate-generated.mjs",
    "prepack": "pnpm run generate"
  },
  "packageManager": "pnpm@10.11.0",
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
