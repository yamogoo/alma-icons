{
  "name": "alma",
  "version": "3.6.1",
  "description": "A production icon system built for consistency - crafted across multiple stroke weights for seamless integration into any UI.",
  "keywords": [
    "icons",
    "svg",
    "design",
    "alma",
    "ui"
  ],
  "main": "index.js",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "yamogoo",
    "email": "grebennikovmisha@gmail.com",
    "fullName": "Mikhail Grebennikov",
    "url": "https://github.com/yamogoo"
  },
  "scripts": {
    "generate": "pnpm --dir packages/alma-icons exec ts-node --esm ./scripts/generate-manifest.ts",
    "validate": "node packages/alma-icons/scripts/validate-generated.mjs",
    "prepack": "pnpm run generate && pnpm run validate"
  },
  "packageManager": "pnpm@10.11.0"
}
